# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV="development"             # "development" | "production"
TRUST_PROXY=                       # Set when behind a reverse proxy (true | 1 | IP)

# ── Database ────────────────────────────────────────
MONGODB_URL=                       # MongoDB Atlas connection string

# ── CORS ────────────────────────────────────────────
FRONTEND_URL=""
FRONTEND_WWW_URL=""

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=                        # Generate a random 64-char hex string
JWT_EXPIRE="5d"
COOKIE_EXPIRE=7

# ── Email (Brevo / Sendinblue) ──────────────────────
BREVO_API_KEY=                     # Set "dummy" to skip sending in dev
BREVO_SENDER_EMAIL="noreply@samridhienterprises.com"
BREVO_SENDER_NAME="Samridhi Enterprises"

# ── Image Storage (Cloudinary) ──────────────────────
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OTP ─────────────────────────────────────────────
# Set to "dev" to log OTPs to the console instead of sending emails.
# Leave empty or set to "production" for normal email-based delivery.
OTP_MODE="production"

